{
  "uid": "infra",
  "title": "Infrastructure",
  "tags": ["infra"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Redis ops/sec",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "ops"},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(redis_commands_processed_total[1m])",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Qdrant collection size (points)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "qdrant_collection_points_total",
          "legendFormat": "{{collection}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Postgres active connections",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "pg_stat_activity_count{state=\"active\"}",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Tempo trace ingest rate (spans/s)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "ops"},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(tempo_distributor_spans_received_total[1m])",
          "legendFormat": "{{receiver}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Kafka consumer lag",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "description": "No-op if Kafka isn't in the stack — kafka-exporter target stays absent and the panel reads empty.",
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kafka_consumergroup_lag) by (consumergroup, topic)",
          "legendFormat": "{{consumergroup}} / {{topic}}"
        }
      ]
    }
  ]
}
