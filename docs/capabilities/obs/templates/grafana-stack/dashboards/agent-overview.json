{
  "uid": "agent-overview",
  "title": "Agent Overview",
  "tags": ["agent", "llm"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "LLM call rate (req/s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "reqps"},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(llm_calls_total[5m])",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "LLM latency p95 (s)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "s"},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(llm_request_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "{{model}} p95"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Token-cost burn (24h USD)",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD"},
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(llm_token_cost_usd_total[24h]))"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Error rate by tool",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "percentunit"},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(tool_calls_total{status=\"error\"}[5m])) by (tool) / clamp_min(sum(rate(tool_calls_total[5m])) by (tool), 0.001)",
          "legendFormat": "{{tool}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request count by recipe",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "reqps"},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(agent_requests_total[5m])) by (recipe)",
          "legendFormat": "{{recipe}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Current model",
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "none"},
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "/^model$/"},
        "textMode": "name"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(1, agent_active_model_info)",
          "format": "table",
          "instant": true
        }
      ]
    }
  ]
}
