{
  "name": "@agent-deployments/common",
  "version": "0.1.0",
  "description": "Shared utilities for agent-deployments prototypes",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./auth": "./dist/auth/index.js",
    "./observability": "./dist/observability/index.js",
    "./ratelimit": "./dist/ratelimit/index.js",
    "./mcp": "./dist/mcp/index.js",
    "./logging": "./dist/logging/index.js",
    "./testing": "./dist/testing/index.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "@hono/node-server": "^1.13.0",
    "jose": "^5.9.0",
    "pino": "^9.5.0",
    "ioredis": "^5.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  }
}
